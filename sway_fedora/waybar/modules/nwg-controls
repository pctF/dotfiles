{
  "group/nwg-controls": {
    "orientation": "horizontal",
    "drawer": {
      "transition-duration": 300,
      "children-class": "nwg-menu-item",
      "transition-left-to-right": false
    },
    "modules": [
      "custom/nwg-icon",
      "custom/processes",
      "custom/wallpapers",
      "custom/gtk",
      "custom/displays",
      "custom/shell",
      "custom/exit"
    ]
  },
  "custom/nwg-icon": {
    "format": "  ",
    "tooltip": "System Menu"
  },
  "custom/processes": {
    "format": "  Processes",
    "on-click": "nwg-processes",
    "tooltip": "Process Manager"
  },
  "custom/wallpapers": {
    "format": "  Wallpapers",
    "on-click": "azote",
    "tooltip": "Change Wallpaper"
  },
  "custom/gtk": {
    "format": "  GTK Settings",
    "on-click": "nwg-look",
    "tooltip": "GTK Theme Settings"
  },
  "custom/displays": {
    "format": "  Displays",
    "on-click": "nwg-displays",
    "tooltip": "Display Settings"
  },
  "custom/shell": {
    "format": "󱓞  Shell Settings",
    "on-click": "nwg-shell-config",
    "tooltip": "nwg-shell configuration"
  },
  "custom/exit": {
    "format": "  Exit",
    "on-click": "nwg-bar",
    "tooltip": "Logout / Power"
  }
}

